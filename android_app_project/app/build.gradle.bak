        // Expose versionName to Java via BuildConfig.VERSION_NAME
        // (used by UpdateChecker for version comparison)
        buildConfigField "String", "VERSION_NAME", "\"${versionName}\""
    }

    buildFeatures {
        buildConfig true      // Ensure BuildConfig class is generated
    }

    buildTypes {
        release {
            minifyEnabled false
            proguardFiles getDefaultProguardFile('proguard-android-optimize.txt'), 'proguard-rules.pro'
        }
    }

    compileOptions {
        sourceCompatibility JavaVersion.VERSION_1_8
        targetCompatibility JavaVersion.VERSION_1_8
    }
}

dependencies {
    // AndroidX Browser — provides Custom Tabs API (backwards compatible to API 21).
    // Transitively includes androidx.core, which provides:
    //   - NotificationCompat  (used by WifiService)
    //   - FileProvider        (used by UpdateChecker)
    //   - ContextCompat       (used by ConnectivityChecker)
    implementation 'androidx.browser:browser:1.8.0'
}
