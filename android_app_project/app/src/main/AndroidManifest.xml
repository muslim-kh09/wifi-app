<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Core network ──────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- WiFi transport detection (ConnectivityChecker.isWifiConnected) -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ── Location (runtime permission — required for WiFi AP identification) ── -->
    <!--
        ACCESS_FINE_LOCATION is required by Android 9+ for WifiManager to return
        real SSID/BSSID data. Also enables the gateway IP resolution used by
        ConnectivityChecker. Requested at runtime before portal launch.
    -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- ── Battery Optimization Exemption ───────────────────────────────────── -->
    <!--
        REQUEST_IGNORE_BATTERY_OPTIMIZATIONS allows the app to ask the system
        to whitelist it from Doze mode, ensuring WifiService heartbeat pings
        continue firing even when the screen is off or the phone is locked.
    -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- ── Notifications (runtime permission on API 33+) ─────────────────── -->
    <!--
        POST_NOTIFICATIONS became a runtime permission in Android 13 (API 33).
        MainActivity requests it at runtime before starting the foreground service.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ── Foreground Service ────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!--
        FOREGROUND_SERVICE_DATA_SYNC pairs with foregroundServiceType="dataSync".
        Unlike connectedDevice, dataSync has NO hardware-connection precondition,
        so it works on any device regardless of Bluetooth/USB/NFC state.
        Required on API 34+; harmless on lower API levels.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- ── APK Auto-Update ───────────────────────────────────────────────── -->
    <!-- Allows the system package installer to be invoked for downloaded APKs -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!--
        Needed to write the downloaded APK to getExternalFilesDir().
        maxSdkVersion="28": Android 10+ (API 29) does not require this for app-private dirs.
    -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!--
        Android 11+ (API 30) Package Visibility:
        Without this block, PackageManager.queryIntentActivities() returns an empty list,
        causing the Custom Tabs browser-detection probe to fail silently.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <!-- Needed so the system can resolve the package installer -->
        <intent>
            <action android:name="android.intent.action.INSTALL_PACKAGE" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:roundIcon="@drawable/ic_launcher"
        android:label="Khaled-CLI"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true">

        <!--
            launchMode="singleTop": tapping the notification brings MainActivity
            to the front via onNewIntent() instead of creating a new instance.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LogViewerActivity"
            android:exported="false"
            android:theme="@android:style/Theme.NoTitleBar" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths" />
        </provider>

        <!-- ── Foreground Service ─────────────────────────────────────────── -->
        <!--
            foregroundServiceType="dataSync":
              - Appropriate for services that communicate with a remote server.
              - No hardware-connection precondition (unlike connectedDevice).
              - Pairs with FOREGROUND_SERVICE_DATA_SYNC permission (enforced API 34+).
              - The matching ServiceInfo constant is used in startForeground() on API 29+.
        -->
        <service
            android:name=".WifiService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- ── FileProvider for APK install on API 24+ ────────────────────── -->
        <!--
            Generates a content:// URI for the downloaded APK so the system
            package installer can read it without MANAGE_EXTERNAL_STORAGE.
            The authority must match FILE_PROVIDER_AUTHORITY in UpdateChecker.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.khaledcli.wifimedia.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

    </application>

</manifest>
