<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Top Action Bar -->
    <RelativeLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1E1E1E"
        android:elevation="4dp"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="الشبكة المحلية"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_debug_console"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_manage"
            android:tint="#888888"
            android:contentDescription="سجل النظام" />
    </RelativeLayout>

    <!-- Welcome Section -->
    <LinearLayout
        android:id="@+id/welcome_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/top_bar"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_dialog_info"
            android:tint="#3B82F6"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="أهلاً بك في بوابة الشبكة"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_network_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="حالة الشبكة: متصل بالبوابة المحلية"
            android:textColor="#A0A0A0"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Dual-Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/welcome_section"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:gravity="center">

        <!-- Button 1 (Port 8080) -->
        <Button
            android:id="@+id/btn_internet_portal"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="تسجيل الدخول / فتح الإنترنت"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#3B82F6"
            android:layout_marginBottom="16dp"
            android:elevation="2dp" />

        <!-- Button 2 (Port 8090) -->
        <Button
            android:id="@+id/btn_local_ecosystem"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="الشبكة المحلية والسوشيال المجاني"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:backgroundTint="#2D2D2D"
            android:elevation="2dp" />

    </LinearLayout>

    <!-- Version string at bottom -->
    <TextView
        android:id="@+id/tv_version"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="16dp"
        android:text="الإصدار 1.0.0"
        android:textColor="#555555"
        android:textSize="12sp"/>

</RelativeLayout>
