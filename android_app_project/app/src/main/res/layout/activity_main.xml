<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0B0B">

    <!-- Settings Icon (Top-Right) -->
    <ImageButton
        android:id="@+id/btn_debug_console"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_manage"
        app:tint="#666666"
        android:contentDescription="سجل النظام" />

    <!-- 15% Top Guideline for Hero Section -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.15" />

    <!-- Hero Logo -->
    <ImageView
        android:id="@+id/iv_logo"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@mipmap/ic_launcher"
        app:layout_constraintTop_toBottomOf="@id/guideline_top"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- NexusFi Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NexusFi"
        android:fontFamily="sans-serif-thin"
        android:letterSpacing="0.1"
        android:textColor="#FFFFFF"
        android:textSize="42sp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/iv_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Primary Button (Stacked above secondary) -->
    <Button
        android:id="@+id/btn_internet_portal"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="16dp"
        android:text="تسجيل الدخول / فتح الإنترنت"
        android:textColor="#0B0B0B"
        android:textStyle="bold"
        android:textSize="16sp"
        android:backgroundTint="#FFFFFF"
        app:cornerRadius="50dp"
        app:layout_constraintBottom_toTopOf="@id/btn_local_ecosystem"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Secondary Button (Stacked above version) -->
    <Button
        android:id="@+id/btn_local_ecosystem"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="24dp"
        android:text="الشبكة المحلية والسوشيال المجاني"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:backgroundTint="#1C1C1E"
        app:cornerRadius="50dp"
        app:layout_constraintBottom_toTopOf="@id/tv_version"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Version Footer -->
    <TextView
        android:id="@+id/tv_version"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        tools:text="الإصدار 3.0.0"
        android:textColor="#444446"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
